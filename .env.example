# ============================================================
# LigjetBot — Environment Variables Template
# Kopjo këtë si .env dhe plotëso me vlerat reale
# ============================================================

# ── GROQ API ─────────────────────────────────────────────────
# Regjistrohu FALAS: https://console.groq.com
# Klik "API Keys" → "Create API Key" — fillon me gsk_...
GROQ_API_KEY=your-groq-api-key-here

# ── MODEL SETTINGS ───────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile

# Embedding model (HuggingFace - FALAS, local, offline)
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── PATHS ────────────────────────────────────────────────────
VECTOR_STORE_PATH=./vector_store/faiss_index
PDF_FOLDER=./data/pdfs

# ── CHUNKING (Faza 1) ────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── RAG SETTINGS (Faza 2) ────────────────────────────────────
TOP_K_RESULTS=5
TEMPERATURE=0.1
