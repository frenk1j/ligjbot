# ============================================================
# LIGJBOT — Environment Variables Template
# Kopjo këtë si .env dhe plotëso me vlerat reale
# ============================================================

# ── GROQ API ─────────────────────────────────────────────────
# Regjistrohu FALAS: https://console.groq.com
# Klik "API Keys" → "Create API Key" — fillon me gsk_...
GROQ_API_KEY=your_api

# ── MODEL SETTINGS ───────────────────────────────────────────
LLM_MODEL=llama-3.1-8b-instant

# Embedding model (HuggingFace - FALAS, local, offline)
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── PATHS ────────────────────────────────────────────────────
VECTOR_STORE_PATH=./vector_store/faiss_index
PDF_FOLDER=./data/pdfs

# ── CHUNKING (Faza 1) ────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── RAG SETTINGS (Faza 2) ────────────────────────────────────
TOP_K_RESULTS=3
FAST_TOP_K=2
TEMPERATURE=0.1

MAX_TOKENS=512
CONTEXT_CHARS_PER_CHUNK=800

# Sa Q/A pairs ruajme per cdo user ne memorien e serverit
MAX_TURNS_HISTORY=5

# Fast retrieval-only responses (1=on, 0=use full LLM)
FAST_MODE=0

# ── FIREBASE (Auth + Firestore) ──────────────────────────
# console.firebase.google.com → Project Settings → Web App
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── HOSTING (Render, Railway, etj.) ─────────────────────
# URL publike pa slash në fund, p.sh. https://ligjbot.onrender.com
PUBLIC_BASE_URL=
