# ============================================================
# LIGJBOT — Environment Variables
# Kopjo si .env dhe plotëso me vlerat e tua
# ============================================================

# ── Groq API (https://console.groq.com) ──────────────────────
GROQ_API_KEY=

# ── Model ────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=intfloat/multilingual-e5-large
TEMPERATURE=0.55
MAX_TOKENS=650

# ── Paths ────────────────────────────────────────────────────
VECTOR_STORE_PATH=./vector_store/faiss_index
PDF_FOLDER=./data/pdfs

# ── RAG ──────────────────────────────────────────────────────
TOP_K_RESULTS=3
FAST_TOP_K=2
FAST_MODE=0
USE_HYBRID=1
CONTEXT_CHARS_PER_CHUNK=800
MAX_TURNS_HISTORY=5
ANSWER_CACHE_MAX=128
LEGAL_SCORE_MAX=0.82

# ── Chunking ─────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Firebase (opsional — Auth + Firestore) ───────────────────
# Firebase Console → Project Settings → Your apps → Web
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Hosting (opsional) ───────────────────────────────────────
# URL publike pa slash në fund
PUBLIC_BASE_URL=

# ── Server ───────────────────────────────────────────────────
PORT=5001
FLASK_DEBUG=0
